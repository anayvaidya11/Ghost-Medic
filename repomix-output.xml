  spo2: number;     // % oxygen saturation
};

export type Injury = {
  region: string;     // e.g. "right chest", "left thigh"
  type: string;       // e.g. "GSW", "blast frag", "burn"
  severity: 'minor' | 'moderate' | 'severe' | 'critical';
  notes?: string;
};

export type Casualty = {
  callsign: string;
  age: number;
  sex: 'M' | 'F';
  weightKg: number;
